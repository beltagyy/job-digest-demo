---
type Props = {
  type?: string;
  name: string;
  placeholder?: string;
  required?: boolean;
  ariaLabel?: string;
  ariaDescribedBy?: string;
  error?: string;
  class?: string;
};

const { 
  type = 'text',
  name,
  placeholder,
  required = false,
  ariaLabel,
  ariaDescribedBy,
  error,
  class: customClass = ''
} = Astro.props;

const baseStyles = 'w-full px-4 py-3 bg-white/5 border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent disabled:opacity-50 disabled:cursor-not-allowed transition-all duration-150';

const errorStyles = error ? 'border-error' : 'border-white/20 hover:border-white/30';

const classes = `${baseStyles} ${errorStyles} ${customClass}`;
---

<div class="flex flex-col gap-2">
  <input
    type={type}
    name={name}
    placeholder={placeholder}
    required={required}
    aria-label={ariaLabel || placeholder}
    aria-describedby={error ? `${name}-error` : ariaDescribedBy}
    class={classes}
    autocomplete={type === 'email' ? 'email' : type === 'tel' ? 'tel' : 'off'}
  />
  {error && (
    <p id={`${name}-error`} class="text-error text-sm font-medium" role="alert">
      {error}
    </p>
  )}
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    input {
      transition: none;
    }
  }
  
  /* Remove auto-fill background color */
  input:-webkit-autofill {
    -webkit-box-shadow: 0 0 0 1000px rgba(255, 255, 255, 0.05) inset;
    -webkit-text-fill-color: #f8fafc;
  }
</style>
