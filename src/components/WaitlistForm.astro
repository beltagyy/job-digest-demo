<form id="waitlist-form" class="space-y-4 max-w-md mx-auto">
  <input type="email" name="email" placeholder="your@email.com" required class="w-full px-4 py-2 border rounded-lg" />
  <input type="text" name="name" placeholder="Your name" required class="w-full px-4 py-2 border rounded-lg" />
  <select name="country" class="w-full px-4 py-2 border rounded-lg">
    <option>Choose country...</option>
    <option>🇩🇪 Germany</option>
    <option>🇳🇱 Netherlands</option>
    <option>🇫🇷 France</option>
    <option>🇪🇸 Spain</option>
    <option>🇬🇧 UK</option>
  </select>
  <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-purple-600 text-white py-3 rounded-lg font-semibold hover:opacity-90">
    Join Waitlist
  </button>
</form>

<script>
  document.getElementById('waitlist-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thanks! We'll be in touch soon.');
    (e.target as HTMLFormElement).reset();
  });
</script>
