---
type Props = {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  class?: string;
  children?: any;
};

const { 
  href, 
  variant = 'primary', 
  size = 'md',
  disabled = false,
  class: customClass = '',
  children 
} = Astro.props;

const baseStyles = 'font-display font-bold transition-all duration-200 ease-in-out-cubic focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-accent disabled:opacity-50 disabled:cursor-not-allowed';

const sizeMap = {
  sm: 'px-3 py-2 text-sm min-h-[40px]',
  md: 'px-5 py-3 text-base min-h-[48px]',
  lg: 'px-8 py-4 text-lg min-h-[56px]',
};

const variantMap = {
  primary: 'bg-gradient-to-r from-brand-accent to-brand-cyan text-brand-dark hover:shadow-accent-lg hover:scale-105 active:scale-95',
  secondary: 'border border-white/30 text-white hover:bg-white/10 hover:border-white/50 active:bg-white/20',
  ghost: 'text-brand-accent hover:bg-brand-accent/10 active:bg-brand-accent/20',
};

const classes = `${baseStyles} ${sizeMap[size]} ${variantMap[variant]} ${customClass}`;
---

{href ? (
  <a href={href} class={`${classes} inline-flex items-center justify-center rounded-lg`}>
    <slot />
  </a>
) : (
  <button disabled={disabled} class={`${classes} rounded-lg cursor-pointer`}>
    <slot />
  </button>
)}

<style>
  @media (prefers-reduced-motion: reduce) {
    button, a {
      transition: none;
      animation: none;
    }
  }
</style>
